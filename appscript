/** Minimal API: record start & finish to the Attempts sheet **/

function sheet(name){ return SpreadsheetApp.getActive().getSheetByName(name); }

function doPost(e) {
  try {
    var action  = (e && e.parameter && e.parameter.action) || "";
    var payload = (e && e.parameter && e.parameter.payload) ? JSON.parse(e.parameter.payload) : {};

    if (e && e.parameter) {
      if (payload.percentCorrect == null && e.parameter.percentCorrect != null) {
        payload.percentCorrect = e.parameter.percentCorrect;
      }
    }

    if (action === "startAttempt") {
      return json(startAttempt_(payload));
    }
    if (action === "finishAttempt") {
      return json(finishAttempt_(payload));
    }
    return jsonErr("Unknown action: " + action);
  } catch (err) {
    return jsonErr(String(err && err.message || err));
  }
}

function json(o){ return ContentService.createTextOutput(JSON.stringify(o)).setMimeType(ContentService.MimeType.JSON); }
function jsonErr(m){ return json({ ok:false, error:m }); }

const TZ = 'America/Vancouver';
function nowVancouverISO(date) {
  return Utilities.formatDate(date || new Date(), TZ, 'yyyy-MM-dd HH:mm:ss');
}

/** Start attempt: create row; no puzzle lookup needed **/
function startAttempt_(p){
  var weekId = String(p.weekId||"").trim();
  var name = String(p.name||"").trim();
  var studentNumber = String(p.studentNumber||"").trim();
  var email = String(p.email||"").trim();
  var lab = String(p.lab||"").trim();

  if(!weekId || !name || !studentNumber || !email || !lab){
    return { ok:false, error:"Missing fields" };
  }

  const sh = sheet('Attempts');
    if (!sh) return { ok:false, error:"Missing 'Attempts' sheet" };

  const attemptId = Utilities.getUuid();
  const start = new Date();
  sh.appendRow([
    attemptId,
    weekId,
    name,
    studentNumber,
    email,
    lab,
    nowVancouverISO(start), // startIso in local time
    '',
    '',
    '',
    '',
    '',                       // new column L for elapsedDisplay
    start.getTime()
  ]);
  return { ok: true, attemptId };
}

function parsePercentCorrect(v) {
  // Treat null/undefined/empty as "no value"
  if (v === null || v === undefined) return '';

  // Normalize some common junk values
  if (v === '' || v === 'null' || v === 'NaN' || v === 'undefined') return '';

  // Try to convert to number
  var n = Number(v);
  if (isNaN(n)) return '';  // still garbage → treat as missing

  return n;
}

function renderGridHtml(user, sol, rows, cols) {
  const cell = 'width:20px;height:20px;text-align:center;font-weight:bold;border:1px solid #ddd;';
  let html = '<table cellspacing="0" cellpadding="0" style="border-collapse:collapse;">';
  for (let r = 0; r < rows; r++) {
    html += '<tr>';
    for (let c = 0; c < cols; c++) {
      const idx = r * cols + c;
      if (sol[idx] === '#') {
        html += `<td style="${cell}background:#111;"></td>`;
        continue;
      }
      const letter = user[idx] || '';
      const correct = letter && letter === sol[idx];
      html += `<td style="${cell}color:${correct ? '#0a0' : '#d00'};">${letter || '&nbsp;'}</td>`;
    }
    html += '</tr>';
  }
  return html + '</table>';
}

// If you don't pass solutionString from the client, fetch it from your public JSON
function fetchSolutionString(weekId) {
  // Update this URL to your public raw puzzles path
  const url = `https://raw.githubusercontent.com/bmbgsaubc/bmb-crossword-site/main/puzzles/${weekId}.json`;
  const res = UrlFetchApp.fetch(url, { muteHttpExceptions: true });
  if (res.getResponseCode() !== 200) throw new Error('Puzzle JSON not found for ' + weekId);
  const json = JSON.parse(res.getContentText());
  if (json.solutionString) return json.solutionString.toUpperCase();
  const layout = json.layout || [];
  return layout.join('').toUpperCase(); // flatten layout
}

function normalizePercentCorrect(v) {
  if (v === null || v === undefined || v === '' || v === 'null' || v === 'NaN' || v === 'undefined') return '';
  var n = Number(v);
  if (isNaN(n)) return '';
  if (n <= 1 && n >= 0) n = n * 100; // handle 0–1 fractions
  n = Math.max(0, Math.min(100, n));  // clamp to 0–100
  return n;
}
function formatMs_(ms) {
  var totalSeconds = Math.floor(ms / 1000);
  var minutes = Math.floor(totalSeconds / 60);
  var seconds = totalSeconds % 60;
  return ('0' + minutes).slice(-2) + ':' + ('0' + seconds).slice(-2);
}
function finishAttempt_(p) {
  Logger.log("finishAttempt_ payload: " + JSON.stringify(p));

  var attemptId = String(p.attemptId||"").trim();
  var percentCorrect = normalizePercentCorrect(p.percentCorrect);
  var userGridString = (p.userGridString || "").toString().toUpperCase();
  var rows = Number(p.rows || 0);
  var cols = Number(p.cols || 0);
  var weekId = String(p.weekId || "").trim();
  var solutionString = (p.solutionString || "").toString().toUpperCase();

  if(!attemptId) return { ok:false, error:"Missing attemptId" };
  if(!rows || !cols) return { ok:false, error:"Missing rows/cols" };

  var sh = sheet("Attempts");
  if (!sh) return { ok:false, error:"Missing 'Attempts' sheet" };

  var data = sh.getDataRange().getValues();
  var r = -1;
  for (var i=1;i<data.length;i++){
    if (data[i][0] === attemptId){ r = i; break; }
  }
  if (r < 0) return { ok:false, error:"Attempt not found" };
  if (data[r][7]) return { ok:false, error:"Attempt already finished" };

  const startIso = data[r][6]; // G
  const startMs = startIso ? new Date(startIso).getTime() : 0;
  if (!startMs) return { ok:false, error:"Missing start timestamp" };

  if (!solutionString) solutionString = fetchSolutionString(weekId);

  const finish = new Date();
  const finishIso = Utilities.formatDate(finish, TZ, 'yyyy-MM-dd HH:mm:ss');
  const elapsedMs = finish.getTime() - startMs;

  var clientActiveMs = Number(p.activeMs);
  if (isNaN(clientActiveMs) || clientActiveMs < 0) clientActiveMs = null;
  var clientPausedMs = Number(p.pausedMs != null ? p.pausedMs : (p.pausedTotalMs || 0));
  if (isNaN(clientPausedMs) || clientPausedMs < 0) clientPausedMs = null;

  const activeMs = (clientActiveMs != null)
    ? Math.min(elapsedMs, clientActiveMs)
    : Math.max(0, elapsedMs - (clientPausedMs || 0));
  const pausedMs = Math.max(0, elapsedMs - activeMs);

  const elapsedDisplay = "'" + formatMs_(elapsedMs);
  const activeDisplay = "'" + formatMs_(activeMs);

  const isCorrect = percentCorrect !== '' && percentCorrect >= 100;

  // H–M
  sh.getRange(r + 1, 8, 1, 6).setValues([[
    finishIso,          // H
    elapsedMs,          // I
    isCorrect,         // J
    percentCorrect === '' ? '' : percentCorrect, // K
    elapsedDisplay,     // L
    userGridString      // M
  ]]);

  // N–P
  sh.getRange(r + 1, 14, 1, 3).setValues([[
    rows,       //N
    cols,       //O
    weekId      //P
  ]]);

  // Q–S
  sh.getRange(r + 1, 17, 1, 3).setValues([[
    pausedMs,        // Q
    activeMs,        // R
    activeDisplay    // S
  ]]);

  // Email the player (optional)
  const email = data[r][4]; // E
  if (email) {
    const gridHtml = renderGridHtml(userGridString, solutionString, rows, cols);
    const pctText = percentCorrect === '' ? 'No score reported' : `${percentCorrect}%`;
    MailApp.sendEmail({
      to: email,
      subject: `Your ${weekId} crossword results`,
      htmlBody: `<p>You scored ${pctText}.</p>
                 <p>Official: ${formatMs_(activeMs)} • Active: ${(activeMs/1000).toFixed(1)}s</p>
                 ${gridHtml}`
    });
  }

  const percentOut = (percentCorrect === '' ? null : percentCorrect);
  return { ok: true, elapsedMs, activeMs, pausedMs, percentCorrect: percentOut };
}

/** Weekly ranked submissions email **/

const WEEKLY_RESULTS_EMAIL_TO = 'bmbgs.ubc@gmail.com';
const ATTEMPTS_COLS = {
  ATTEMPT_ID: 0,
  WEEK_ID: 1,
  NAME: 2,
  STUDENT_NUMBER: 3,
  EMAIL: 4,
  LAB: 5,
  START_ISO: 6,
  FINISH_ISO: 7,
  ELAPSED_MS: 8,
  IS_CORRECT: 9,
  PERCENT_CORRECT: 10,
  ELAPSED_DISPLAY: 11,
  USER_GRID_STRING: 12,
  ROWS: 13,
  COLS: 14,
  WEEK_ID_DUP: 15,
  PAUSED_MS: 16,
  ACTIVE_MS: 17,
  ACTIVE_DISPLAY: 18
};

function onOpen() {
  var ui = SpreadsheetApp.getUi();
  ui.createMenu('Crossword')
    .addItem('Preview weekly ranking email', 'previewLatestWeeklyRankingEmail')
    .addItem('Send weekly ranking email now', 'sendLatestWeeklyRankingEmail')
    .addSeparator()
    .addItem('Install Wednesday email trigger', 'installWeeklyRankingEmailTrigger')
    .addToUi();
}

function previewLatestWeeklyRankingEmail() {
  var result = buildLatestWeeklyRankingEmail_();
  Logger.log(result.textBody);
  SpreadsheetApp.getUi().alert(result.preview);
  return result;
}

function sendLatestWeeklyRankingEmail() {
  var result = buildLatestWeeklyRankingEmail_();
  MailApp.sendEmail({
    to: WEEKLY_RESULTS_EMAIL_TO,
    subject: result.subject,
    body: result.textBody,
    htmlBody: result.htmlBody,
    name: 'BMB Crossword'
  });

  Logger.log('Sent ranked submissions email for ' + result.weekId + ' to ' + WEEKLY_RESULTS_EMAIL_TO);
  return result;
}

function installWeeklyRankingEmailTrigger() {
  var triggers = ScriptApp.getProjectTriggers();
  for (var i = 0; i < triggers.length; i++) {
    if (triggers[i].getHandlerFunction() === 'sendLatestWeeklyRankingEmail') {
      ScriptApp.deleteTrigger(triggers[i]);
    }
  }

  ScriptApp.newTrigger('sendLatestWeeklyRankingEmail')
    .timeBased()
    .onWeekDay(ScriptApp.WeekDay.WEDNESDAY)
    .atHour(21)
    .create();

  SpreadsheetApp.getUi().alert(
    'Installed the Wednesday 9 PM trigger. Apps Script may run it at a randomized time within the 9 PM hour.'
  );
}

function buildLatestWeeklyRankingEmail_() {
  var weekId = detectLatestCompletedWeekId_();
  var entries = buildRankedWeeklySubmissions_(weekId);
  if (!entries.length) {
    throw new Error('No completed submissions found for ' + weekId + '.');
  }

  return {
    weekId: weekId,
    subject: 'BMB Weekly Crossword ranked submissions - ' + weekId,
    textBody: buildWeeklyRankingText_(weekId, entries),
    htmlBody: buildWeeklyRankingHtml_(weekId, entries),
    preview: buildWeeklyRankingPreview_(weekId, entries)
  };
}

function detectLatestCompletedWeekId_() {
  var rows = getAttemptRows_();
  for (var i = rows.length - 1; i >= 0; i--) {
    var attempt = parseAttemptRow_(rows[i]);
    if (attempt && attempt.weekId) return attempt.weekId;
  }
  throw new Error("Could not determine the latest completed week from the 'Attempts' sheet.");
}

function buildRankedWeeklySubmissions_(weekId) {
  var rows = getAttemptRows_();
  var entries = [];

  for (var i = 0; i < rows.length; i++) {
    var attempt = parseAttemptRow_(rows[i]);
    if (!attempt) continue;
    if (attempt.weekId !== weekId) continue;
    entries.push(attempt);
  }

  entries.sort(compareRankedAttempts_);
  return entries;
}

function getAttemptRows_() {
  var sh = sheet('Attempts');
  if (!sh) throw new Error("Missing 'Attempts' sheet");

  var values = sh.getDataRange().getValues();
  if (!values.length) return [];

  var startIndex = looksLikeHeaderRow_(values[0]) ? 1 : 0;
  var rows = [];
  for (var i = startIndex; i < values.length; i++) {
    rows.push({
      rowNumber: i + 1,
      values: values[i]
    });
  }
  return rows;
}

function looksLikeHeaderRow_(row) {
  var colA = String(row[ATTEMPTS_COLS.ATTEMPT_ID] || '').toLowerCase();
  var colB = String(row[ATTEMPTS_COLS.WEEK_ID] || '').toLowerCase();
  var colK = String(row[ATTEMPTS_COLS.PERCENT_CORRECT] || '').toLowerCase();
  return colA.indexOf('attempt') !== -1 || colB.indexOf('week') !== -1 || colK.indexOf('percent') !== -1;
}

function parseAttemptRow_(record) {
  var row = record.values;
  var weekId = String(row[ATTEMPTS_COLS.WEEK_ID] || row[ATTEMPTS_COLS.WEEK_ID_DUP] || '').trim();
  var finishIso = String(row[ATTEMPTS_COLS.FINISH_ISO] || '').trim();
  var percentCorrect = normalizePercentCorrect(row[ATTEMPTS_COLS.PERCENT_CORRECT]);
  if (!weekId || !finishIso || percentCorrect === '') return null;

  var activeMs = toNumberOrNull_(row[ATTEMPTS_COLS.ACTIVE_MS]);
  if (activeMs === null) {
    activeMs = parseDurationDisplayMs_(row[ATTEMPTS_COLS.ACTIVE_DISPLAY]);
  }
  if (activeMs === null) {
    activeMs = toNumberOrNull_(row[ATTEMPTS_COLS.ELAPSED_MS]);
  }
  if (activeMs === null) {
    activeMs = parseDurationDisplayMs_(row[ATTEMPTS_COLS.ELAPSED_DISPLAY]);
  }
  if (activeMs === null) return null;

  return {
    rowNumber: record.rowNumber,
    attemptId: String(row[ATTEMPTS_COLS.ATTEMPT_ID] || '').trim(),
    weekId: weekId,
    name: String(row[ATTEMPTS_COLS.NAME] || '').trim(),
    studentNumber: String(row[ATTEMPTS_COLS.STUDENT_NUMBER] || '').trim(),
    email: String(row[ATTEMPTS_COLS.EMAIL] || '').trim(),
    lab: String(row[ATTEMPTS_COLS.LAB] || '').trim(),
    finishIso: finishIso,
    percentCorrect: percentCorrect,
    activeMs: activeMs,
    activeDisplay: cleanDisplayTime_(row[ATTEMPTS_COLS.ACTIVE_DISPLAY]) || formatMs_(activeMs)
  };
}

function compareRankedAttempts_(a, b) {
  if (a.percentCorrect !== b.percentCorrect) return b.percentCorrect - a.percentCorrect;
  if (a.activeMs !== b.activeMs) return a.activeMs - b.activeMs;

  var aFinish = parseDateMs_(a.finishIso);
  var bFinish = parseDateMs_(b.finishIso);
  if (aFinish !== bFinish) return aFinish - bFinish;

  return a.rowNumber - b.rowNumber;
}

function buildWeeklyRankingPreview_(weekId, entries) {
  var lines = ['Latest ranked submissions for ' + weekId];
  for (var i = 0; i < entries.length; i++) {
    var entry = entries[i];
    lines.push(
      (i + 1) + '. ' + (entry.name || 'Unknown') +
      ' - ' + entry.percentCorrect + '% - ' + entry.activeDisplay
    );
  }
  return lines.join('\n');
}

function buildWeeklyRankingText_(weekId, entries) {
  var lines = [
    'BMB Weekly Crossword',
    'All ranked submissions for ' + weekId,
    '',
    'Ranked by percent correct first, then active time.',
    ''
  ];

  for (var i = 0; i < entries.length; i++) {
    var entry = entries[i];
    lines.push(
      (i + 1) + '. ' + (entry.name || 'Unknown') +
      ' | ' + (entry.email || '-') +
      ' | ' + (entry.lab || '-') +
      ' | ' + entry.percentCorrect + '%' +
      ' | ' + entry.activeDisplay +
      ' | ' + entry.finishIso
    );
  }

  lines.push('');
  lines.push('Generated automatically on ' + nowVancouverISO(new Date()) + '.');
  return lines.join('\n');
}

function buildWeeklyRankingHtml_(weekId, entries) {
  var rows = [];
  for (var i = 0; i < entries.length; i++) {
    var entry = entries[i];
    rows.push(
      '<tr>' +
        '<td style="padding:8px 10px;border-bottom:1px solid #e5e7eb;">' + (i + 1) + '</td>' +
        '<td style="padding:8px 10px;border-bottom:1px solid #e5e7eb;">' + escapeHtml_(entry.name || 'Unknown') + '</td>' +
        '<td style="padding:8px 10px;border-bottom:1px solid #e5e7eb;">' + escapeHtml_(entry.email || '-') + '</td>' +
        '<td style="padding:8px 10px;border-bottom:1px solid #e5e7eb;">' + escapeHtml_(entry.lab || '-') + '</td>' +
        '<td style="padding:8px 10px;border-bottom:1px solid #e5e7eb;">' + entry.percentCorrect + '%</td>' +
        '<td style="padding:8px 10px;border-bottom:1px solid #e5e7eb;">' + escapeHtml_(entry.activeDisplay) + '</td>' +
        '<td style="padding:8px 10px;border-bottom:1px solid #e5e7eb;">' + escapeHtml_(entry.finishIso) + '</td>' +
      '</tr>'
    );
  }

  return (
    '<div style="font-family:Arial,Helvetica,sans-serif;color:#111827;">' +
      '<h2>All ranked submissions for ' + escapeHtml_(weekId) + '</h2>' +
      '<p>Ranked by percent correct first, then active time.</p>' +
      '<table cellspacing="0" cellpadding="0" style="border-collapse:collapse;width:100%;">' +
        '<thead>' +
          '<tr>' +
            '<th align="left" style="padding:8px 10px;border-bottom:2px solid #cbd5e1;">#</th>' +
            '<th align="left" style="padding:8px 10px;border-bottom:2px solid #cbd5e1;">Name</th>' +
            '<th align="left" style="padding:8px 10px;border-bottom:2px solid #cbd5e1;">Email</th>' +
            '<th align="left" style="padding:8px 10px;border-bottom:2px solid #cbd5e1;">Lab</th>' +
            '<th align="left" style="padding:8px 10px;border-bottom:2px solid #cbd5e1;">Score</th>' +
            '<th align="left" style="padding:8px 10px;border-bottom:2px solid #cbd5e1;">Active Time</th>' +
            '<th align="left" style="padding:8px 10px;border-bottom:2px solid #cbd5e1;">Submitted</th>' +
          '</tr>' +
        '</thead>' +
        '<tbody>' + rows.join('') + '</tbody>' +
      '</table>' +
      '<p style="margin-top:16px;color:#4b5563;">Generated automatically on ' + escapeHtml_(nowVancouverISO(new Date())) + '.</p>' +
    '</div>'
  );
}

function parseDurationDisplayMs_(value) {
  var cleaned = cleanDisplayTime_(value);
  if (!cleaned) return null;

  var parts = cleaned.split(':');
  if (parts.length !== 2 && parts.length !== 3) return null;

  var nums = [];
  for (var i = 0; i < parts.length; i++) {
    var n = Number(parts[i]);
    if (isNaN(n)) return null;
    nums.push(n);
  }

  var hours = 0;
  var minutes = 0;
  var seconds = 0;
  if (nums.length === 2) {
    minutes = nums[0];
    seconds = nums[1];
  } else {
    hours = nums[0];
    minutes = nums[1];
    seconds = nums[2];
  }

  return ((hours * 3600) + (minutes * 60) + seconds) * 1000;
}

function cleanDisplayTime_(value) {
  var s = String(value || '').trim();
  if (!s) return '';
  return s.replace(/^'+/, '');
}

function toNumberOrNull_(value) {
  if (value === null || value === undefined || value === '') return null;
  var n = Number(value);
  return isNaN(n) ? null : n;
}

function parseDateMs_(value) {
  var ms = new Date(value).getTime();
  return isNaN(ms) ? Number.MAX_SAFE_INTEGER : ms;
}

function escapeHtml_(value) {
  return String(value || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}
